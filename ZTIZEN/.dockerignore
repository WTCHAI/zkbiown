# Docker ignore file for ZTIZEN monorepo
# Prevents unnecessary files from being copied to Docker build context

# Node modules (will be installed in Docker)
**/node_modules
node_modules

# Build outputs
**/dist
**/build
**/.next
**/.turbo

# Development files
**/.git
**/.gitignore
**/.env.local
**/.env.*.local

# Test files
**/__tests__
**/*.test.js
**/*.test.ts
**/*.spec.js
**/*.spec.ts
**/tests
**/test
**/.coverage

# Documentation
**/README.md
**/docs
**/CHANGELOG.md

# IDE files
**/.vscode
**/.idea
**/.DS_Store
**/*.swp
**/*.swo
**/*~

# Logs
**/logs
**/*.log
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/pnpm-debug.log*

# Temporary files
**/tmp
**/temp
**/.tmp

# Experimental (not needed in production)
experimental

# Smart contracts (not needed for services)
smart-contracts

# Circuit files (large, not needed for services)
circuit

# Docker files themselves
**/Dockerfile
**/docker-compose*.yml
**/.dockerignore
