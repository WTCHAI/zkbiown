{
  "name": "@zkbiown/web",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "compile:circuit": "cd ../circuit && nargo compile",
    "test:circuit": "cd ../circuit && nargo test",
    "download:models": "./download-models.sh",
