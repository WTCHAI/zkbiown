    "@privy-io/react-auth": "^3.8.0",
    "@tanstack/react-router": "^1.139.12",
    "@tanstack/router-plugin": "^1.139.12",
    "@tensorflow/tfjs-node": "^4.22.0",
    "@vladmandic/face-api": "^1.7.15",
    "axios": "^1.13.2",
    "canvas": "^3.2.1",
