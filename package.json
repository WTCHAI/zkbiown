{
  "name": "@zkbiown/monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "ZK BIOWN - Cancelable Biometric Authentication with Zero-Knowledge Proofs",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/zk-biown"
  },
  "scripts": {
    "install": "pnpm install",
    "dev": "pnpm -r --parallel run dev",
    "dev:web": "pnpm --filter @zkbiown/web run dev",
    "dev:product": "pnpm --filter @zkbiown/product-service run dev",
    "dev:ztizen": "pnpm --filter @zkbiown/ztizen-service run dev",
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "clean": "pnpm -r run clean && rm -rf node_modules",
    "compile:circuit": "cd ZTIZEN/circuit && nargo compile",
    "experiment:uniqueness": "pnpm --filter @zkbiown/web run experiment:uniqueness"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "@types/node": "^22.18.11"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
